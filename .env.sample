# Configuración de MongoDB Atlas
MONGODB_URI=mongodb+srv://<usuario>:<contraseña>@<cluster>.mongodb.net/<base>?retryWrites=true&w=majority

# SMTP para correo de recuperación de contraseña
EMAIL_USER=tu-correo@gmail.com
EMAIL_PASS=tu-contraseña-o-app-password

# Clave secreta para la sesión
SESSION_SECRET=una-clave-secreta-larga
